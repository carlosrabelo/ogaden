# ==============================================================================
# Ogaden - Environment Configuration
# Copy to .env and fill in the values you need to override.
#
# SIGNAL LEVELS OVERVIEW
# -----------------------
# Signals are routed across three levels:
#
#   LEVEL1_SIGNALS  — Primary gate: at least one must confirm BUY/SELL.
#                     Default: EMA,TREND
#
#   LEVEL2_SIGNALS  — Confirmations: need LEVEL2_MIN signals to agree.
#                     Default: RSI,MACD,BB,STOCH (min=1)
#
#   LEVEL3_SIGNALS  — Hard gate: ALL signals in this set must agree.
#                     Default: empty (disabled)
#
# Available signal names: EMA, TREND, SMA, RSI, MACD, STOCH, BB, VOL
#
# Examples:
#   LEVEL1_SIGNALS=EMA,TREND      # require EMA or TREND crossover
#   LEVEL2_SIGNALS=RSI,MACD       # need at least 1 of RSI/MACD to confirm
#   LEVEL2_MIN=2                  # require 2 confirmations instead of 1
#   LEVEL3_SIGNALS=VOL            # volume must also agree (hard gate)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# Required (live mode only; ignored when SANDBOX=true)
# ------------------------------------------------------------------------------
# API_KEY=
# API_SECRET=

# ------------------------------------------------------------------------------
# Mode
# ------------------------------------------------------------------------------
# SANDBOX=true

# ------------------------------------------------------------------------------
# Assets & Data
# ------------------------------------------------------------------------------
BASE_ASSET=BTC
QUOTE_ASSET=USDT
INTERVAL=15m
LIMIT=500
TIMEZONE=America/Cuiaba

# ------------------------------------------------------------------------------
# Sandbox Balances (only used when SANDBOX=true)
# ------------------------------------------------------------------------------
BASE_BALANCE=0.0
QUOTE_BALANCE=10.0

# ------------------------------------------------------------------------------
# Indicators (windows and thresholds)
# ------------------------------------------------------------------------------
# FAST_SMA=7
# SLOW_SMA=14
# TREND_SMA=50
# FAST_EMA=7
# SLOW_EMA=14
# TREND_EMA=50
# RSI_PERIOD=14
# RSI_BUY_THRESHOLD=40
# RSI_SELL_THRESHOLD=60

# ------------------------------------------------------------------------------
# Profit / Loss / Trailing
# Set to 0.0 to disable (recommended: use ATR-based SL/TP only)
# ------------------------------------------------------------------------------
# PROFIT_THRESHOLD=0.0
# LOSS_THRESHOLD=0.0
# TRAILING_THRESHOLD=0.0      # Balance-based trailing (% drawdown from peak balance)
# TRAILING_STOP_PCT=0.0       # Price-based trailing stop (% below price peak). 0 = disabled

# ------------------------------------------------------------------------------
# Signal Levels
# ------------------------------------------------------------------------------
# LEVEL1_SIGNALS=SMA
# LEVEL2_SIGNALS=
# LEVEL2_MIN=1
# LEVEL3_SIGNALS=

# ------------------------------------------------------------------------------
# Memcached (for dashboard)
# ------------------------------------------------------------------------------
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# ------------------------------------------------------------------------------
# Persistence (state file location)
# ------------------------------------------------------------------------------
STATE_FILE=data/state.json

# ------------------------------------------------------------------------------
# Dashboard (web interface)
# ------------------------------------------------------------------------------
DASHBOARD_PORT=3501
DASHBOARD_POLL_INTERVAL=2

# ==============================================================================
# RISK MANAGEMENT
# ==============================================================================

# Position size % of balance per trade
# POSITION_SIZE_PCT=25.0

# Trend filter EMA period (higher = more conservative, only trade with long-term trend)
# TREND_FILTER_EMA=100

# Cooldown cycles after losing trade (0 = disabled)
# COOLDOWN_CYCLES=5

# Minimum trade margin % — skip trades if expected move (ATR) is below this
# MIN_TRADE_MARGIN_PCT=0.3

# ATR stop-loss multiplier (higher = wider stops)
# ATR_STOP_MULTIPLIER=2.0

# ------------------------------------------------------------------------------
# Circuit Breaker (automatic trading halt on excessive losses)
# Set to 0 to disable each check independently
# ------------------------------------------------------------------------------
# MAX_DRAWDOWN_PCT=15.0       # Halt if sum of losses in last 20 trades >= this %
# MAX_CONSECUTIVE_LOSSES=5    # Halt after N consecutive losing trades
# To resume after a circuit breaker trigger: set circuit_breaker_active=false in data/state.json
