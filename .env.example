# ==============================================================================
# Ogaden - Environment Configuration
# Copy to .env and fill in the values you need to override.
#
# STRATEGY MODE OVERVIEW
# -----------------------
# The STRATEGY_MODE sets all default values for the bot. You only need to
# override specific values in this file if you want fine-tuned adjustments.
#
# Available modes: conservative | balanced | aggressive
#
# CONSERVATIVE (Safe Trading)
#   - Position size: 15% of balance
#   - Cooldown: 10 cycles after loss
#   - Trend filter: EMA 200 (long-term trend)
#   - Min margin: 0.5% expected move
#   - Stop loss: 2x ATR
#   - Profit/Loss: 1% forced exit
#   - Confirmations: 2 (very strict)
#   - Volume gate: Required
#
# BALANCED (Moderate Trading)
#   - Position size: 25% of balance
#   - Cooldown: 5 cycles after loss
#   - Trend filter: EMA 100 (medium-term trend)
#   - Min margin: 0.3% expected move
#   - Stop loss: 2x ATR
#   - Profit/Loss: Disabled (use ATR-based SL/TP only)
#   - Confirmations: 1 (moderate)
#   - Volume gate: Not required
#
# AGGRESSIVE (Active Trading)
#   - Position size: 35% of balance
#   - Cooldown: 0 cycles (no cooldown)
#   - Trend filter: EMA 50 (short-term trend)
#   - Min margin: 0.2% expected move
#   - Stop loss: 1.5x ATR (tighter stops)
#   - Profit/Loss: Disabled (use ATR-based SL/TP only)
#   - Confirmations: 0 (no confirmations needed)
#   - Volume gate: Not required
#
# HOW TO USE THIS FILE
# ---------------------
# 1. Set STRATEGY_MODE to your preferred mode (conservative/balanced/aggressive)
# 2. Uncomment and override specific values ONLY if you want different defaults
# 3. Most users don't need to change anything beyond STRATEGY_MODE
#
# ==============================================================================

# ------------------------------------------------------------------------------
# Required (live mode only; ignored when SANDBOX=true)
# ------------------------------------------------------------------------------
# API_KEY=
# API_SECRET=

# ------------------------------------------------------------------------------
# Mode
# ------------------------------------------------------------------------------
# SANDBOX=true

# ------------------------------------------------------------------------------
# Assets & Data
# ------------------------------------------------------------------------------
BASE_ASSET=BTC
QUOTE_ASSET=USDT
INTERVAL=15m
LIMIT=500
TIMEZONE=America/Cuiaba

# ------------------------------------------------------------------------------
# Sandbox Balances (only used when SANDBOX=true)
# ------------------------------------------------------------------------------
BASE_BALANCE=0.0
QUOTE_BALANCE=10.0

# ------------------------------------------------------------------------------
# Indicators (windows and thresholds)
# Override ONLY if you want different strategy defaults
# ------------------------------------------------------------------------------
# FAST_SMA=7
# SLOW_SMA=14
# TREND_SMA=50
# FAST_EMA=7
# SLOW_EMA=14
# TREND_EMA=50
# RSI_PERIOD=14
# RSI_BUY_THRESHOLD=40
# RSI_SELL_THRESHOLD=60

# ------------------------------------------------------------------------------
# Profit / Loss / Trailing
# Override ONLY if you want different strategy defaults
# Set to 0.0 to disable (recommended for most strategies)
# ------------------------------------------------------------------------------
# PROFIT_THRESHOLD=0.0
# LOSS_THRESHOLD=0.0
# TRAILING_THRESHOLD=0.0

# ------------------------------------------------------------------------------
# Strategy Mode (sets all defaults)
# Available: conservative | balanced | aggressive
# ------------------------------------------------------------------------------
STRATEGY_MODE=balanced

# ------------------------------------------------------------------------------
# Memcached (for dashboard)
# ------------------------------------------------------------------------------
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211

# ------------------------------------------------------------------------------
# Persistence (state file location)
# ------------------------------------------------------------------------------
STATE_FILE=data/state.json

# ------------------------------------------------------------------------------
# Dashboard (web interface)
# ------------------------------------------------------------------------------
DASHBOARD_PORT=3501
DASHBOARD_POLL_INTERVAL=2

# ==============================================================================
# RISK MANAGEMENT (override ONLY if you want different strategy defaults)
# ==============================================================================

# Position size % of balance per trade (conservative=15, balanced=25, aggressive=35)
# POSITION_SIZE_PCT=25.0

# Trend filter EMA period (conservative=200, balanced=100, aggressive=50)
# Higher values = more conservative, only trade with long-term trend
# Lower values = more active, allow short-term trends
# TREND_FILTER_EMA=100

# Cooldown cycles after losing trade (conservative=10, balanced=5, aggressive=0)
# Set to 0 to disable cooldown
# COOLDOWN_CYCLES=5

# Minimum trade margin % (conservative=0.5, balanced=0.3, aggressive=0.2)
# Skip trades if expected move (based on ATR) is below this threshold
# MIN_TRADE_MARGIN_PCT=0.3

# ATR stop-loss multiplier (conservative=2.0, balanced=2.0, aggressive=1.5)
# Multiplier used for dynamic stop-loss and take-profit calculation
# Higher = wider stops, lower = tighter stops
# ATR_STOP_MULTIPLIER=2.0
